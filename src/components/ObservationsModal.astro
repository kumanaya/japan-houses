---
// ObservationsModal.astro - Modal para editar observações de um imóvel
interface Props {
  propertyId: string | null;
  currentObs: string;
  onClose: () => void;
  onSave: (id: string, value: string) => void;
}

const { propertyId, currentObs, onClose, onSave } = Astro.props;
---

<div class="modal-bg open" onclick={onClose}>
  <div class="modal modal-obs" onclick={(e: any) => e.stopPropagation()}>
    <h3>📝 Editar Observações</h3>
    {propertyId && (
      <p style="font-size: 12px; color: #666; margin-bottom: 12px;">
        Imóvel: <b>{propertyId}</b>
      </p>
    )}
    <textarea
      class="obs-textarea"
      placeholder="Digite suas anotações aqui..."
      rows="8"
      oninput={(e: any) => onSave(propertyId!, e.target.value)}
    >{currentObs}</textarea>
    <div style="display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px;">
      <button class="modal-cancel" onclick={onClose}>Cancelar</button>
      <button class="modal-save" onclick={onClose}>Salvar</button>
    </div>
  </div>
</div>

<style>
  .modal-obs {
    min-width: 400px;
    max-width: 500px;
  }
  .obs-textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #d0d0d0;
    border-radius: 8px;
    font-family: inherit;
    font-size: 13px;
    line-height: 1.5;
    resize: vertical;
    min-height: 150px;
    background: #fffef8;
  }
  .obs-textarea:focus {
    outline: none;
    border-color: #0071e3;
    background: #fff;
  }
  .modal-cancel {
    padding: 8px 16px;
    border-radius: 6px;
    border: 1px solid #d0d0d0;
    background: #fff;
    color: #555;
    cursor: pointer;
    font-size: 12px;
  }
  .modal-cancel:hover { background: #f5f5f7; }
  .modal-save {
    padding: 8px 16px;
    border-radius: 6px;
    border: 1px solid #0071e3;
    background: #0071e3;
    color: #fff;
    cursor: pointer;
    font-size: 12px;
  }
  .modal-save:hover { background: #005a9e; }
</style>
